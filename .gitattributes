# Normalize line endings to LF on commit (cross-platform safety)
* text=auto eol=lf

# --- Source files ---
*.py        text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.env       text eol=lf
*.sh        text eol=lf
*.mermaid   text eol=lf

# --- Binary files (no diff, no line-ending conversion) ---
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.sqlite3   binary

# SVG is XML text — keep as text but treat as non-diffable in GitHub UI
*.svg       text eol=lf

# Prevent noisy diffs on generated lock files
package-lock.json   merge=ours
